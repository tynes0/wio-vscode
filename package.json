{
  "name": "wio-vscode",
  "displayName": "Wio",
  "description": "VS Code support for the Wio language.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "main": "./src/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "activationEvents": [
    "onLanguage:wio",
    "onCommand:wio.checkCurrentFile",
    "onCommand:wio.runCurrentFile",
    "onCommand:wio.emitCppCurrentFile",
    "onCommand:wio.showBackendInfoCurrentFile",
    "onCommand:wio.clearDiagnostics"
  ],
  "contributes": {
    "languages": [
      {
        "id": "wio",
        "aliases": [
          "Wio",
          "wio"
        ],
        "extensions": [
          ".wio"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/wio-file-light.svg",
          "dark": "./assets/wio-file-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "wio",
        "scopeName": "source.wio",
        "path": "./syntaxes/wio.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "wio",
        "path": "./snippets/wio.json"
      }
    ],
    "commands": [
      {
        "command": "wio.checkCurrentFile",
        "title": "Check Current File",
        "category": "Wio",
        "icon": "$(check)"
      },
      {
        "command": "wio.runCurrentFile",
        "title": "Run Current File",
        "category": "Wio",
        "icon": "$(play)"
      },
      {
        "command": "wio.emitCppCurrentFile",
        "title": "Emit Generated C++",
        "category": "Wio",
        "icon": "$(file-code)"
      },
      {
        "command": "wio.showBackendInfoCurrentFile",
        "title": "Show Backend Info",
        "category": "Wio",
        "icon": "$(tools)"
      },
      {
        "command": "wio.clearDiagnostics",
        "title": "Clear Diagnostics",
        "category": "Wio",
        "icon": "$(clear-all)"
      }
    ],
    "configuration": {
      "title": "Wio",
      "properties": {
        "wio.executable": {
          "type": "string",
          "default": "wio",
          "description": "Path or command name for the Wio compiler executable."
        },
        "wio.defaultArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Default extra arguments passed to every Wio compiler invocation."
        },
        "wio.enableDiagnosticsOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run `wio --dry-run` for the current Wio file after save."
        },
        "wio.enableDiagnosticsOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Run `wio --dry-run` for the current Wio file when it is opened."
        },
        "wio.showOutputOnSuccess": {
          "type": "boolean",
          "default": false,
          "description": "Reveal the Wio output channel even when a command succeeds."
        },
        "wio.runArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Extra arguments appended after `--run` when running the current Wio file."
        }
      }
    },
    "keybindings": [
      {
        "command": "wio.checkCurrentFile",
        "key": "ctrl+alt+w",
        "mac": "cmd+alt+w",
        "when": "editorLangId == wio && editorTextFocus"
      },
      {
        "command": "wio.runCurrentFile",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorLangId == wio && editorTextFocus"
      },
      {
        "command": "wio.emitCppCurrentFile",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorLangId == wio && editorTextFocus"
      },
      {
        "command": "wio.showBackendInfoCurrentFile",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorLangId == wio && editorTextFocus"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "wio.checkCurrentFile",
          "when": "editorLangId == wio"
        },
        {
          "command": "wio.runCurrentFile",
          "when": "editorLangId == wio"
        },
        {
          "command": "wio.emitCppCurrentFile",
          "when": "editorLangId == wio"
        },
        {
          "command": "wio.showBackendInfoCurrentFile",
          "when": "editorLangId == wio"
        },
        {
          "command": "wio.clearDiagnostics",
          "when": "editorLangId == wio"
        }
      ],
      "editor/title": [
        {
          "command": "wio.checkCurrentFile",
          "when": "resourceExtname == .wio",
          "group": "navigation@100"
        },
        {
          "command": "wio.runCurrentFile",
          "when": "resourceExtname == .wio",
          "group": "navigation@101"
        },
        {
          "command": "wio.emitCppCurrentFile",
          "when": "resourceExtname == .wio",
          "group": "navigation@102"
        }
      ]
    }
  },
  "keywords": [
    "wio",
    "language",
    "compiler",
    "interop",
    "scripting"
  ]
}

{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Wio",
  "scopeName": "source.wio",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#realmAndModules"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#calls"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.wio",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.wio"
            }
          },
          "end": "$\\n?"
        },
        {
          "name": "comment.block.wio",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.wio"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.wio"
            }
          }
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "storage.modifier.attribute.wio",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.wio",
          "begin": "\\$?\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.wio",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.wio",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "#numbers"
                },
                {
                  "include": "#keywords"
                },
                {
                  "include": "#types"
                },
                {
                  "include": "#calls"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.wio",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.wio",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.wio",
          "match": "\\b\\d+(?:\\.\\d+)?(?:[iu](?:8|16|32|64|size)|f(?:32|64))?\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.wio",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "keyword.control.default.wio",
          "match": "\\bassumed\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.wio",
          "match": "\\b(?:use|as|realm)\\b"
        },
        {
          "name": "keyword.control.flow.wio",
          "match": "\\b(?:if|else|while|for|foreach|match|when|return|break|continue|and|or|not|is|fit|every|after|during|wait|async|await|coroutine|yield|thread|loop|system|program)\\b"
        },
        {
          "name": "storage.modifier.wio",
          "match": "\\b(?:let|mut|const|ref|view|public|private|protected)\\b"
        },
        {
          "name": "storage.type.declaration.wio",
          "match": "\\b(?:fn|object|component|interface|enum|flagset|flag)\\b"
        },
        {
          "name": "variable.language.wio",
          "match": "\\b(?:self|super)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.wio",
          "match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|isize|usize|byte|bool|char|uchar|string|void|object)\\b"
        }
      ]
    },
    "realmAndModules": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(::)",
          "captures": {
            "1": {
              "name": "entity.name.namespace.wio"
            },
            "2": {
              "name": "punctuation.separator.namespace.wio"
            }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\bfn\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.wio"
            }
          }
        },
        {
          "match": "\\b(?:object|component|interface|enum|flagset|flag|realm)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.wio"
            }
          }
        },
        {
          "match": "\\b(?:let|mut|const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "variable.other.definition.wio"
            }
          }
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "support.function.wio"
            }
          }
        },
        {
          "match": "\\.([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "support.function.method.wio"
            }
          }
        }
      ]
    }
  }
}
